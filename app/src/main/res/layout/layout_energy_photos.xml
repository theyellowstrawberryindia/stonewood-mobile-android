<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/backgroundWhite">

    <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
        android:id="@+id/labelEnergyPhotos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_standard"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/bold"
        android:textSize="@dimen/text_size_small"
        tools:text="Photos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:letterSpacingMultiplier="0.23" />

    <GridLayout
        android:id="@+id/gridEnergyPhotos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margin_standard"
        android:columnCount="3"
        android:orientation="horizontal"
        android:useDefaultMargins="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/labelEnergyPhotos" />

</androidx.constraintlayout.widget.ConstraintLayout>