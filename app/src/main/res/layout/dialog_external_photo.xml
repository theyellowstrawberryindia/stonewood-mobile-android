<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="onTakeNewPhoto"
            type="android.view.View.OnClickListener" />

        <variable
            name="onUseExisting"
            type="android.view.View.OnClickListener" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:background="@color/backgroundWhite"
            tools:ignore="UselessParent">

            <ImageView
                android:id="@+id/imageExternalPhoto"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="48dp"
                android:adjustViewBounds="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_external_photo" />

            <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                android:id="@+id/dialogTitleExternalPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_dialog"
                android:layout_marginTop="34dp"
                android:fontFamily="@font/bold"
                android:text="@string/ext_photo_dialog_header"
                android:textAlignment="center"
                android:textSize="@dimen/text_size_xlarge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.3"
                app:layout_constraintStart_toEndOf="@+id/imageExternalPhoto"
                app:layout_constraintTop_toTopOf="parent"
                app:letterSpacingMultiplier="0.2" />

            <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                android:id="@+id/dialogDescriptionExternalPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_dialog"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/light"
                android:text="@string/ext_photo_dialog_message"
                android:textAlignment="center"
                android:textSize="@dimen/text_size_medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/imageExternalPhoto"
                app:layout_constraintTop_toBottomOf="@id/dialogTitleExternalPhoto"
                app:letterSpacingMultiplier="0.2" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrierExternalPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="dialogDescriptionExternalPhoto, imageExternalPhoto" />

            <View
                android:id="@+id/separatorExternalPhoto"
                android:layout_width="match_parent"
                android:layout_height="@dimen/separator_size"
                android:layout_marginTop="40dp"
                android:background="@color/separator"
                app:layout_constraintTop_toBottomOf="@id/barrierExternalPhoto"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/separatorExternalPhoto">

                <Button
                    android:id="@+id/negativeButtonExternalPhoto"
                    style="@style/DialogButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:onClick="@{onTakeNewPhoto}"
                    android:text="@string/take_new_photo" />

                <View
                    android:id="@+id/buttonSeparatorExternalPhoto"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="match_parent"
                    android:background="@color/separator" />

                <Button
                    android:id="@+id/positiveButtonExternalPhoto"
                    style="@style/DialogButtonStyle"
                    android:layout_width="0dp"
                    android:onClick="@{onUseExisting}"
                    android:text="@string/use_existing"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</layout>