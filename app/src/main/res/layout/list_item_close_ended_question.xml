<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="34dp"
    android:paddingHorizontal="@dimen/margin_standard">

    <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
        android:id="@+id/textViewCloseEndedQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/regular"
        android:textSize="@dimen/text_size_medium"
        app:layout_constraintBottom_toTopOf="@+id/yesButtonCloseEndedQuestion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:letterSpacingMultiplier="0.46" />

    <Button
        android:id="@+id/yesButtonCloseEndedQuestion"
        android:layout_width="84dp"
        android:layout_height="@dimen/bottom_button_height"
        android:text="@string/yes"
        style="@style/QuestionButtonStyle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textViewCloseEndedQuestion"
        app:layout_constraintTop_toBottomOf="@+id/textViewCloseEndedQuestion"/>

    <Button
        android:id="@+id/noButtonCloseEndedQuestion"
        android:layout_width="84dp"
        android:layout_height="@dimen/bottom_button_height"
        android:text="@string/no"
        android:layout_marginStart="12dp"
        style="@style/QuestionButtonStyle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/yesButtonCloseEndedQuestion"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintStart_toEndOf="@+id/yesButtonCloseEndedQuestion"
        app:layout_constraintTop_toTopOf="@+id/yesButtonCloseEndedQuestion" />

</androidx.constraintlayout.widget.ConstraintLayout>