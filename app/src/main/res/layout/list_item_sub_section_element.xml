<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
            android:id="@+id/titleSubSectionElement"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/regular"
            android:labelFor="@id/userEntryEditTextSubSectionElement"
            android:textSize="@dimen/text_size_xxsmall"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:letterSpacingMultiplier="0.2" />

        <uk.co.savills.stonewood.util.customview.ComboBox
            android:id="@+id/comboBoxSubSectionElement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/titleSubSectionElement" />

        <EditText
            android:id="@+id/userEntryEditTextSubSectionElement"
            style="@style/EditTextStyle.SingleLine"
            android:layout_width="match_parent"
            android:layout_marginTop="6dp"
            android:imeOptions="actionDone"
            app:layout_constraintTop_toBottomOf="@+id/titleSubSectionElement"
            tools:ignore="TextFields" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>