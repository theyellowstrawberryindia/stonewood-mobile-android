<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/backgroundWhite">

    <uk.co.savills.stonewood.util.customview.EmptyView
        android:id="@+id/emptyViewProjectTotal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:header="@string/data_empty_view_header"
        app:image="@drawable/ic_no_project" />

    <View
        android:id="@+id/columnProjectTotal"
        android:layout_width="@dimen/separator_size"
        android:layout_height="match_parent"
        android:background="@color/separatorDark"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.2"
        app:layout_constraintStart_toStartOf="parent" />

    <uk.co.savills.stonewood.util.customview.AppRecyclerView
        android:id="@+id/sectionsProjectTotal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/columnProjectTotal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/columnProjectTotal">

        <RelativeLayout
            android:id="@+id/statisticsContainerProjectTotal"
            android:layout_width="match_parent"
            android:paddingVertical="32dp"
            android:visibility="gone"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/legendProjectTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_standard"
                android:background="@color/colorPrimary">

                <View
                    android:id="@+id/tableTopBorderProjectTotal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/separator_size"
                    android:background="@color/separatorDark"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/tableLegendStartSeparatorProjectTotal"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="0dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintBottom_toTopOf="@id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintStart_toStartOf="@id/tableTopBorderProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/strataLabelProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bold"
                    android:text="@string/strata"
                    android:textColor="@color/textWhite"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn1ProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <View
                    android:id="@+id/tableColumn1ProjectTotal"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="0dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintBottom_toTopOf="@id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toEndOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintHorizontal_bias="0.2"
                    app:layout_constraintStart_toStartOf="@+id/tableLegendStartSeparatorProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/requiredLabelProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:text="@string/required"
                    android:textColor="@color/textWhite"
                    app:layout_constraintBottom_toBottomOf="@+id/strataLabelProjectTotal"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn2ProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableColumn1ProjectTotal"
                    app:layout_constraintTop_toTopOf="@+id/strataLabelProjectTotal" />

                <View
                    android:id="@+id/tableColumn2ProjectTotal"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="0dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintBottom_toTopOf="@id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toEndOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintHorizontal_bias="0.4"
                    app:layout_constraintStart_toStartOf="@+id/tableLegendStartSeparatorProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/achievedLabelProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:text="@string/achieved"
                    android:textColor="@color/textWhite"
                    app:layout_constraintBottom_toBottomOf="@+id/strataLabelProjectTotal"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn3ProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableColumn2ProjectTotal"
                    app:layout_constraintTop_toTopOf="@+id/strataLabelProjectTotal" />

                <View
                    android:id="@+id/tableColumn3ProjectTotal"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="0dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintBottom_toTopOf="@id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toEndOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintHorizontal_bias="0.6"
                    app:layout_constraintStart_toStartOf="@+id/tableLegendStartSeparatorProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/remainingLabelProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:text="@string/remaining"
                    android:textColor="@color/textWhite"
                    app:layout_constraintBottom_toBottomOf="@+id/strataLabelProjectTotal"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn4ProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableColumn3ProjectTotal"
                    app:layout_constraintTop_toTopOf="@+id/strataLabelProjectTotal" />

                <View
                    android:id="@+id/tableColumn4ProjectTotal"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="0dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintBottom_toTopOf="@id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toEndOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintHorizontal_bias="0.8"
                    app:layout_constraintStart_toStartOf="@+id/tableLegendStartSeparatorProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/quantityLabelProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    android:text="@string/complete_label"
                    android:textColor="@color/textWhite"
                    app:layout_constraintBottom_toTopOf="@+id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toStartOf="@+id/tableLegendEndBorderProjectTotal"
                    app:layout_constraintStart_toEndOf="@+id/tableColumn4ProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

                <View
                    android:id="@+id/tableLegendBottomSeparatorProjectTotal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/separator_size"
                    android:layout_marginTop="8dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintEnd_toEndOf="@id/tableTopBorderProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/strataLabelProjectTotal" />

                <View
                    android:id="@+id/tableLegendEndBorderProjectTotal"
                    android:layout_width="@dimen/separator_size"
                    android:layout_height="0dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintBottom_toTopOf="@id/tableLegendBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toEndOf="@+id/tableTopBorderProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/tableTopBorderProjectTotal" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <uk.co.savills.stonewood.util.customview.AppRecyclerView
                android:id="@+id/statisticsProjectTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_below="@id/legendProjectTotal"
                android:layout_alignStart="@+id/legendProjectTotal"
                android:layout_alignEnd="@+id/legendProjectTotal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/totalLayoutProjectTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/statisticsProjectTotal"
                android:layout_alignStart="@+id/statisticsProjectTotal"
                android:layout_alignEnd="@+id/statisticsProjectTotal"
                android:layout_marginTop="32dp">

                <View
                    android:id="@+id/totalTopSeparatorProjectTotal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/separator_size"
                    android:background="@color/separatorDark"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/totalLabelProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bold"
                    android:text="@string/total"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn1GuideLineProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/totalTopSeparatorProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/totalTopSeparatorProjectTotal" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/tableColumn1GuideLineProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.2" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/requiredTotalProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bold"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn2GuideLineProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableColumn1GuideLineProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/totalTopSeparatorProjectTotal"
                    tools:text="223" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/tableColumn2GuideLineProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.4" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/achievedTotalProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bold"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn3GuideLineProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableColumn2GuideLineProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/totalTopSeparatorProjectTotal"
                    tools:text="223" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/tableColumn3GuideLineProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.6" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/remainingTotalProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/bold"
                    app:layout_constraintEnd_toStartOf="@+id/tableColumn4GuideLineProjectTotal"
                    app:layout_constraintStart_toStartOf="@+id/tableColumn3GuideLineProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/totalTopSeparatorProjectTotal"
                    tools:text="223" />

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/tableColumn4GuideLineProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.8" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:id="@+id/completeTotalProjectTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bold"
                    app:layout_constraintBottom_toTopOf="@+id/totalBottomSeparatorProjectTotal"
                    app:layout_constraintEnd_toEndOf="@+id/totalTopSeparatorProjectTotal"
                    app:layout_constraintStart_toEndOf="@+id/tableColumn4GuideLineProjectTotal"
                    app:layout_constraintTop_toBottomOf="@+id/totalTopSeparatorProjectTotal"
                    tools:text="75" />

                <View
                    android:id="@+id/totalBottomSeparatorProjectTotal"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/separator_size"
                    android:layout_marginTop="8dp"
                    android:background="@color/separatorDark"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/totalLabelProjectTotal" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </RelativeLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>