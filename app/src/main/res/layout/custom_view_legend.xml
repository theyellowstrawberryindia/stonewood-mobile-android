<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <View
        android:id="@+id/statusIndicatorLegend"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/background_legend_indicator"
        app:layout_constraintBottom_toBottomOf="@+id/titleLegend"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/titleLegend"
        app:layout_constraintVertical_bias="0.65" />

    <TextView
        android:id="@+id/titleLegend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:fontFamily="@font/light"
        android:textSize="@dimen/text_size_xxsmall"
        app:layout_constraintStart_toEndOf="@+id/statusIndicatorLegend"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>