<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="uk.co.savills.stonewood.screen.survey.contact.ContactDetailViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".screen.survey.contact.ContactDetailFragment">

        <uk.co.savills.stonewood.util.customview.StandardToolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:isLoading="@{viewModel.isBusy}"
            app:title="@string/contact_details" />

        <uk.co.savills.stonewood.util.customview.AppScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/backgroundWhite">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="32dp"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/backgroundGray"
                    android:padding="@dimen/margin_standard">

                    <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                        android:id="@+id/headerTextViewContactDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bold"
                        android:text="@{viewModel.property.UPRN}"
                        android:textSize="@dimen/text_size_medium"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:letterSpacingMultiplier="0.46" />

                    <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                        android:id="@+id/detailsTextViewContactDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/regular"
                        android:text="@{viewModel.property.address.toString()}"
                        android:textSize="@dimen/text_size_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/headerTextViewContactDetail"
                        app:letterSpacingMultiplier="0.46" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_standard"
                    android:layout_marginTop="@dimen/margin_standard"
                    android:fontFamily="@font/bold"
                    android:paddingVertical="6dp"
                    android:textSize="@dimen/text_size_small"
                    app:letterSpacingMultiplier="0.4"
                    app:properCase="@{@string/primary_contact_number}" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_standard"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/regular"
                    android:onClick="@{() -> viewModel.onContactNumberClick()}"
                    android:paddingVertical="6dp"
                    android:text="@{viewModel.contact.number}"
                    android:textSize="@dimen/text_size_medium"
                    app:letterSpacingMultiplier="0.46" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_standard"
                    android:layout_marginTop="42dp"
                    android:fontFamily="@font/bold"
                    android:paddingVertical="6dp"
                    android:textSize="@dimen/text_size_small"
                    app:letterSpacingMultiplier="0.4"
                    app:properCase="@{@string/secondary_contact_number}" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_standard"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/regular"
                    android:onClick="@{() -> viewModel.onSecondaryContactNumberClick()}"
                    android:paddingVertical="6dp"
                    android:text="@{viewModel.contact.numberSecondary}"
                    android:textSize="@dimen/text_size_medium"
                    app:letterSpacingMultiplier="0.46" />

                <View
                    style="@style/SeparatorStyle"
                    android:layout_marginTop="@dimen/margin_standard" />

                <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_standard"
                    android:layout_marginTop="@dimen/margin_standard"
                    android:fontFamily="@font/bold"
                    android:labelFor="@+id/notesEditTextContactDetail"
                    android:text="@string/notes"
                    android:textSize="@dimen/text_size_small"
                    app:letterSpacingMultiplier="0.4" />

                <EditText
                    android:id="@+id/notesEditTextContactDetail"
                    style="@style/EditTextStyle.Multiline"
                    android:layout_width="match_parent"
                    android:layout_height="105dp"
                    android:layout_marginHorizontal="@dimen/margin_standard"
                    android:layout_marginTop="12dp"
                    android:gravity="top"
                    android:text="@={viewModel.contactNotes}" />
            </LinearLayout>
        </uk.co.savills.stonewood.util.customview.AppScrollView>
    </LinearLayout>
</layout>