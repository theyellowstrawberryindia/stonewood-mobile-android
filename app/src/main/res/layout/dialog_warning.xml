<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="64dp"
        android:background="@color/backgroundWhite">

        <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
            android:id="@+id/dialogTitleWarning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:fontFamily="@font/black"
            android:text="@string/warning_dialog_header"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:textSize="@dimen/text_size_xx_large"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.38"
            app:layout_constraintStart_toEndOf="@+id/iconWarning"
            app:layout_constraintTop_toTopOf="parent"
            app:letterSpacingMultiplier="0.2" />

        <ImageView
            android:id="@+id/iconWarning"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginTop="48dp"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_warning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <uk.co.savills.stonewood.util.customview.LetterSpacedTextView
            android:id="@+id/dialogDescriptionWarning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="34dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/regular"
            android:textAlignment="center"
            android:textSize="@dimen/text_size_medium"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iconWarning"
            app:layout_constraintTop_toBottomOf="@+id/dialogTitleWarning"
            app:letterSpacingMultiplier="0.2"
            tools:text="@string/excessive_value_warning_dialog_message"
            tools:ignore="UnusedIds"/>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrierWarning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="dialogDescriptionWarning, iconWarning" />

        <View
            android:id="@+id/separatorWarning"
            android:layout_width="match_parent"
            android:layout_height="@dimen/separator_size"
            android:layout_marginTop="32dp"
            android:background="@color/separator"
            app:layout_constraintTop_toBottomOf="@id/barrierWarning" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/separatorWarning">

            <Button
                android:id="@+id/negativeButtonWarning"
                style="@style/DialogButtonStyle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:visibility="gone" />

            <View
                android:id="@+id/buttonSeparatorWarning"
                android:layout_width="@dimen/separator_size"
                android:layout_height="match_parent"
                android:background="@color/separator"
                android:visibility="gone" />

            <Button
                android:id="@+id/positiveButtonWarning"
                style="@style/DialogButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dialog_standard_button_text" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>