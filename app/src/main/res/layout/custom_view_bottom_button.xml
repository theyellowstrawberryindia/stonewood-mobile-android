<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:id="@+id/separatorBottomButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/separator_size"
            android:background="@color/separator"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/buttonBottomButton"
            style="@style/ButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_button_height"
            android:layout_marginHorizontal="@dimen/margin_standard"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="15dp"
            android:background="@color/buttonEnabled"
            android:fontFamily="@font/bold"
            android:letterSpacing="0.03"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/text_size_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/separatorBottomButton" />

        <ProgressBar
            android:id="@+id/progressBarBottomButton"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:indeterminateTint="@color/progress"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/buttonBottomButton"
            app:layout_constraintEnd_toEndOf="@+id/buttonBottomButton"
            app:layout_constraintStart_toStartOf="@+id/buttonBottomButton"
            app:layout_constraintTop_toTopOf="@+id/buttonBottomButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>