<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr name="isLoading" format="boolean" />
    <attr name="title" format="string" />

    <declare-styleable name="standardToolbar">
        <attr name="title" />
        <attr name="isLoading" />
        <attr name="infoText" format="string" />
        <attr name="isInfoTextVisible" format="boolean" />
        <attr name="optionImage" format="reference" />
        <attr name="optionText" format="string" />
        <attr name="isBackButtonVisible" format="boolean" />
        <attr name="isLogoVisible" format="boolean" />
    </declare-styleable>

    <declare-styleable name="letterSpacedTextView">
        <attr name="letterSpacingMultiplier" format="float" />
    </declare-styleable>

    <declare-styleable name="bottomButton">
        <attr name="text" format="string" />
        <attr name="isLoading" />
        <attr name="isEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="projectOption">
        <attr name="title" />
        <attr name="separatorHeight" format="dimension" />
    </declare-styleable>

    <declare-styleable name="emptyView">
        <attr name="image" format="reference" />
        <attr name="header" format="string" />
    </declare-styleable>

    <declare-styleable name="legendView">
        <attr name="title" />
        <attr name="indicatorColor" format="color" />
    </declare-styleable>
</resources>