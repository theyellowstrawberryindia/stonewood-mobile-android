<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <item name="android:windowBackground">@color/colorPrimary</item>

        <item name="android:textColor">@color/textDefault</item>
        <item name="android:textStyle">normal</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">@color/colorAccent</item>
        <item name="android:windowBackground">@drawable/background_splash</item>
    </style>

    <style name="ImageViewerTheme" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="DialogFragmentStyle" parent="AppTheme">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowAnimationStyle">@style/DialogFragmentAnimationStyle</item>
    </style>

    <style name="DialogFragmentAnimationStyle" parent="@android:style/Animation.Activity">
        <item name="android:windowEnterAnimation">@anim/dialog_enter_anim</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit_anim</item>
    </style>

    <style name="EditTextStyle">
        <item name="android:background">@drawable/background_edit_text</item>
        <item name="fontFamily">@font/regular</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:lineSpacingExtra">7sp</item>
        <item name="android:textSize">@dimen/text_size_small</item>
    </style>

    <style name="EditTextStyle.SingleLine">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/edit_text_height</item>
        <item name="android:padding">@dimen/edit_text_padding</item>
    </style>

    <style name="EditTextStyle.Multiline">
        <item name="android:inputType">textMultiLine</item>
        <item name="android:gravity">top</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ButtonStyle">
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="DialogButtonStyle" parent="ButtonStyle">
        <item name="android:background">@color/transparent</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:textSize">@dimen/text_size_large</item>
        <item name="android:fontFamily">@font/regular</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="QuestionButtonStyle" parent="ButtonStyle">
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_size_small</item>
        <item name="android:fontFamily">@font/bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:background">@drawable/background_button_deselect</item>
    </style>

    <style name="SeparatorStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/separator_size</item>
        <item name="android:background">@color/separator</item>
    </style>

    <style name="CheckBoxStyle">
        <item name="android:fontFamily">@font/bold</item>
        <item name="android:paddingLeft">5dp</item>
        <item name="android:textSize">@dimen/text_size_small</item>
        <item name="android:translationX">-6dp</item>
    </style>

    <style name="TabLayoutTextAppearance" parent="Widget.MaterialComponents.TabLayout">
        <item name="fontFamily">@font/black</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/textLightSecondary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="EditTextHintStyle">
        <item name="android:fontFamily">@font/regular</item>
        <item name="android:textColor">@color/textDefault</item>
        <item name="android:textSize">@dimen/text_size_small</item>
        <item name="letterSpacingMultiplier">0.4</item>
    </style>

</resources>